      "items": [
        {
          "id": "cs0",
          "title": "Fracture Mechanics of Rare-Earth Permanent Magnets",
          "client": "2026 Dana Knox Student Showcase Poster Session",
          "industry": "Computational Mechanics / Magnetoelasticity",
          "image": "/images/posters/dana-knox-2026.jpg",
          "image_fit": "contain",
          "presentation_images": [
            {
              "image": "/images/posters/poster-presentation.jpg",
              "title": "Presenting at the Dana Knox Student Showcase"
            },
            {
              "image": "/images/posters/poster_presentation_with_dr_liu.jpg",
              "title": "Poster presentation with Dr. Xing Liu"
            }
          ],
          "tags": [
            "Poster Presentation",
            "Dana Knox Student Showcase",
            "Rare-Earth Magnets",
            "Fracture Mechanics",
            "NJIT"
          ],
          "summary": "Poster presentation at the 2026 Dana Knox Student Showcase Poster Session, highlighting computational research on deformation and fracture behavior in rare-earth permanent magnets under coupled magneto-mechanical loading.",
          "problem": "Rare-earth permanent magnets are central to modern technologies but are mechanically brittle, creating fracture risks during manufacturing, handling, and high-speed operation.",
          "approach": "Developed a multiphysics continuum framework integrating magnetoelasticity, coupled mechanical and magnetic loading, and data-driven fracture analysis to predict fracture behavior in permanent magnets.",
          "result": "Presented preliminary computational mechanics results and a proposed theoretical framework for improving reliability and mitigating premature failure in rare-earth magnet applications.",
          "metrics": [
            {
              "label": "Event",
              "value": "Dana Knox Student Showcase"
            },
            {
              "label": "Date",
              "value": "April 8, 2026"
            },
            {
              "label": "Institution",
              "value": "NJIT"
            }
          ],
          "link_url": null
        },
        {
          "id": "cs1",
          "title": "Fracture Mechanics of Magnets",
          "client": null,
          "industry": "Computational Mechanics / Materials Science",
          "image": null,
          "tags": [
            "Fracture Mechanics",
            "Magnets",
            "Computational Simulation",
            "NJIT"
          ],
          "summary": "Ongoing graduate research on fracture behavior in magnetic materials using computational mechanics and multiphysics simulation.",
          "problem": "Understanding how magnets fracture under mechanical and magnetic loading is critical for engineering applications in motors, sensors, and structural components. The failure mechanisms in magnetic materials remain an active area of investigation.",
          "approach": "Applying computational simulation frameworks \u2014 including finite element analysis tools such as Abaqus and COMSOL \u2014 to model stress distribution, crack initiation, and propagation in magnetic materials under various loading conditions.",
          "result": "Ongoing research contributing to the fundamental understanding of magneto-mechanical coupling and fracture in permanent magnets, with implications for improving material durability in engineering applications.",
          "metrics": [
            {
              "label": "Institution",
              "value": "NJIT, Newark NJ"
            },
            {
              "label": "Lab",
              "value": "Computational Mechanics & Physics Lab"
            },
            {
              "label": "Status",
              "value": "Active (2025\u2013Present)"
            }
          ],
          "link_url": null
        },
        {
          "id": "cs2",
          "title": "Aerodynamic Analysis of Ahmed Body Model with Underbody Diffuser",
          "client": null,
          "industry": "Computational Fluid Dynamics / Automotive Aerodynamics",
          "image": null,
          "tags": [
            "CFD",
            "ANSYS Fluent",
            "SolidWorks",
            "Aerodynamics",
            "Undergraduate Thesis"
          ],
          "summary": "Undergraduate thesis project analyzing how underbody diffuser geometry affects Ahmed body drag, lift, and flow behavior.",
          "problem": "Underbody diffusers significantly influence vehicle aerodynamics, affecting fuel efficiency and stability. However, computational characterization of their effect on standardized bluff body models (Ahmed body) requires detailed CFD analysis to quantify aerodynamic improvements.",
          "approach": "Used ANSYS Fluent for computational fluid dynamics simulations and SolidWorks for 3D modeling of the Ahmed body geometry with varying diffuser configurations. Tecplot 360 was used for post-processing and visualization of pressure fields, velocity contours, and wake structures.",
          "result": "Successfully characterized the aerodynamic impact of underbody diffuser geometry on the Ahmed body model, providing quantitative insights into drag reduction and downforce generation. Research supervised by Associate Professor Syed Masrur Ahmmad at CUET.",
          "metrics": [
            {
              "label": "Institution",
